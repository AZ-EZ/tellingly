{
  "name": "tellingly",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply tellingly-prod --local",
    "db:migrate:remote": "wrangler d1 migrations apply tellingly-prod --remote",
    "assets:icons": "node scripts/generate-store-assets.mjs",
    "reel:lint": "hyperframes lint marketing/reels/tellingly-daily-ritual",
    "reel:inspect": "hyperframes inspect marketing/reels/tellingly-daily-ritual --samples 10",
    "reel:render": "node scripts/render-reel.mjs",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "gsap": "^3.15.0",
    "hyperframes": "^0.6.69",
    "sharp": "^0.34.5",
    "wrangler": "^4.96.0"
  }
}
